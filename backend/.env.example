# Example .env for backend — copy to .env and fill in values (never commit .env)
MONGODB_URI=mongodb://127.0.0.1:27017/careerDB
JWT_SECRET=replace_with_a_strong_random_value

# SWI-Prolog (optional path)
SWIPL_PATH=C:\Program Files\swipl\bin\swipl.exe

# Gemini — required when skills are outside the Prolog KB or Prolog fails
# Get a key from https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaSyAIyh3rsT7HZ0jpiXxyTCZCd6J6wIlfh10
# Optional model override (default: gemini-2.0-flash)
# GEMINI_MODEL=gemini-2.0-flash

# Optional Google Cloud NLP (not required)
# USE_GOOGLE_NLP=0
